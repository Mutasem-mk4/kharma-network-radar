# Maintainer: Mutasem (@Mutasem-mk4)
# Description: Kharma - The Over-Watch Network Monitor

pkgname=kharma
pkgver=10.0.0
pkgrel=1
pkgdesc="An elite CLI tool mapping active connections to process IDs, geographical locations, and threat intelligence."
arch=('any')
url="https://github.com/Mutaz/kharma-network-radar"
license=('MIT')
groups=('blackarch' 'blackarch-networking')
depends=('python' 'python-click' 'python-rich' 'python-psutil' 'python-requests' 'python-maxminddb' 'python-vt-py' 'python-rich-click' 'python-flask' 'python-flask-cors' 'python-scapy')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("https://files.pythonhosted.org/packages/source/k/kharma-radar/kharma_radar-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/kharma_radar-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/kharma_radar-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
